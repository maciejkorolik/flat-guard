      "parameters": {
        "jsCode": "const input = $input.item.json;\nconst markdown = input.data?.markdown || input.markdown || '';\nconst meta = input.data?.metadata || input.metadata || {};\n\nconst detailUrl = meta.url || meta.sourceURL || input.detailUrl || '';\nconst externalId = input.externalId\n  || detailUrl.match(/-ID([A-Za-z0-9]+)\\.html$/)?.[1]\n  || null;\n\nif (!markdown || !externalId) return [{ json: { _skip: true } }];\n\nreturn [{\n  json: {\n    source: 'olx',\n    externalId,\n    raw: {\n      source: 'olx',\n      external_id: externalId,\n      raw_data: JSON.stringify({\n        url: detailUrl,\n        markdown,\n        metadata: meta,\n        scraped_at: new Date().toISOString()\n      }),\n      scraped_at: new Date().toISOString()\n    }\n  }\n}]"
      },
