        "jsCode": "// Morizon: extract offer links from markdown\n// Real detail URL: https://www.morizon.pl/oferta/wynajem-mieszkanie-<slug>-mzn<numericId>\n// NO trailing slash — regex must NOT require one\nconst input = $input.item.json;\nconst markdown = input.data?.markdown || input.markdown || '';\n\nif (!markdown) {\n  console.log('[Morizon List] Brak markdown dla:', input.listingUrl);\n  return [];\n}\n\n// Match /oferta/...-mzn<numericId> — no trailing slash in actual URLs\nconst linkRegex = /\\(https:\\/\\/www\\.morizon\\.pl\\/oferta\\/([^)\\s]*?-mzn(\\d+))\\)/g;\nconst found = new Map();\nlet match;\n\nwhile ((match = linkRegex.exec(markdown)) !== null) {\n  const slug = match[1];\n  const externalId = match[2];\n  const cleanUrl = `https://www.morizon.pl/oferta/${slug}`;\n\n  if (externalId && !found.has(externalId)) {\n    found.set(externalId, { cleanUrl, externalId });\n  }\n}\n\nconsole.log(`[Morizon List] Znaleziono ${found.size} ogłoszeń Morizon`);\n\nreturn Array.from(found.values()).map(({ cleanUrl, externalId }) => ({\n  json: {\n    city: input.city || 'warszawa',\n    source: 'morizon',\n    detailUrl: cleanUrl,\n    externalId\n  }\n}));"
