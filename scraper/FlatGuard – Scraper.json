      "parameters": {
        "jsCode": "// Otodom: extract offer links from markdown\n// Offer URLs look like: https://www.otodom.pl/pl/oferta/<slug>-ID<id>\nconst input = $input.item.json;\nconst markdown = input.data?.markdown || input.markdown || '';\n\nif (!markdown) {\n  console.log('[Otodom List] Brak markdown dla:', input.listingUrl);\n  return [];\n}\n\n// Match links to /pl/oferta/... paths\nconst linkRegex = /\\(https:\\/\\/www\\.otodom\\.pl\\/pl\\/oferta\\/([^)\\s]+)\\)/g;\nconst found = new Map();\nlet match;\n\nwhile ((match = linkRegex.exec(markdown)) !== null) {\n  const slug = match[1].split('?')[0].replace(/\\/$/, '');\n  const cleanUrl = `https://www.otodom.pl/pl/oferta/${slug}`;\n\n  // ExternalId: last segment after final hyphen or the full slug\n  // Otodom slugs end with -ID<numeric> e.g. kawalerka-na-wynajem-ID123456\n  const externalId = slug.match(/-ID(\\d+)$/)?.[1]\n    || slug.split('/').pop();\n\n  if (externalId && !found.has(externalId)) {\n    found.set(externalId, { cleanUrl, externalId });\n  }\n}\n\nconsole.log(`[Otodom List] Znaleziono ${found.size} ogłoszeń Otodom`);\n\nreturn Array.from(found.values()).map(({ cleanUrl, externalId }) => ({\n  json: {\n    city: input.city || 'warszawa',\n    source: 'otodom',\n    detailUrl: cleanUrl,\n    externalId\n  }\n}));"
      },
