      "parameters": {
        "jsCode": "// Firecrawl zwraca data.markdown — parsujemy linki z formatu markdown [tekst](url)\nconst input = $input.item.json;\nconst markdown = input.data?.markdown || input.markdown || '';\n\nif (!markdown) {\n  console.log('[OLX List] Brak markdown dla:', input.listingUrl);\n  return [];\n}\n\n// Wyciągamy URL-e z linków markdown: (https://www.olx.pl/d/oferta/...)\nconst linkRegex = /\\(https:\\/\\/www\\.olx\\.pl\\/d\\/oferta\\/([^)]+)\\)/g;\nconst found = new Map();\nlet match;\n\nwhile ((match = linkRegex.exec(markdown)) !== null) {\n  const fullPath = match[1].split('?')[0]; // usuń query string\n  const cleanUrl = `https://www.olx.pl/d/oferta/${fullPath}`;\n  \n  // ExternalId z wzorca -ID{id}.html np. CID3-ID19WXzx → ID19WXzx\n  const externalId = fullPath.match(/-ID([A-Za-z0-9]+)\\.html$/)?.[1]\n    || fullPath.replace('.html', '').split('-').pop();\n  \n  if (externalId && !found.has(externalId)) {\n    found.set(externalId, { cleanUrl, externalId });\n  }\n}\n\nconsole.log(`[OLX List] Znaleziono ${found.size} ogłoszeń OLX`);\n\nreturn Array.from(found.values()).map(({ cleanUrl, externalId }) => ({\n  json: {\n    city: input.city || 'warszawa',\n    source: 'olx',\n    detailUrl: cleanUrl,\n    externalId\n  }\n}));"
      },
