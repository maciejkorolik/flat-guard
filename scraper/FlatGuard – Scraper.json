      "parameters": {
        "jsCode": "// Gratka: extract offer links from markdown\n// Real URL format: https://gratka.pl/nieruchomosci/<slug>/<oi|ob>/<numericId>\n// Example: https://gratka.pl/nieruchomosci/mieszkanie-warszawa-ursynow-dereniowa/oi/41593583\nconst input = $input.item.json;\nconst markdown = input.data?.markdown || input.markdown || '';\n\nif (!markdown) {\n  console.log('[Gratka List] Brak markdown dla:', input.listingUrl);\n  return [];\n}\n\n// Match /nieruchomosci/<slug>/<oi|ob>/<numericId>\nconst linkRegex = /\\(https:\\/\\/gratka\\.pl\\/nieruchomosci\\/[^)\\s]+?\\/(oi|ob)\\/(\\d+)\\)/g;\nconst found = new Map();\nlet match;\n\nwhile ((match = linkRegex.exec(markdown)) !== null) {\n  const externalId = match[2];\n  const cleanUrl = match[0].slice(1, -1); // strip surrounding parens\n\n  if (externalId && !found.has(externalId)) {\n    found.set(externalId, { cleanUrl, externalId });\n  }\n}\n\nconsole.log(`[Gratka List] Znaleziono ${found.size} ogłoszeń Gratka`);\n\nreturn Array.from(found.values()).map(({ cleanUrl, externalId }) => ({\n  json: {\n    city: input.city || 'warszawa',\n    source: 'gratka',\n    detailUrl: cleanUrl,\n    externalId\n  }\n}));"
